{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "patchy Helm chart values",
    "type": "object",
    "additionalProperties": false,
    "definitions": {
        "duration": {
            "type": "string",
            "description": "Go duration, e.g. 60s, 2m, 1h30m",
            "pattern": "^([0-9]+(\\.[0-9]+)?(ns|us|µs|ms|s|m|h))+$"
        },
        "logLevel": {
            "type": "string",
            "description": "slog level for the controller's stderr logger",
            "enum": ["debug", "info", "warn", "error"]
        },
        "extraEnv": {
            "type": "object",
            "description": "Verbatim PATCHY_* variable name -> value",
            "additionalProperties": {
                "type": ["string", "number", "boolean"]
            }
        },
        "imageOverride": {
            "type": "object",
            "description": "Key-by-key override of the global image; digest pins and beats any tag",
            "additionalProperties": false,
            "properties": {
                "repository": { "type": "string" },
                "tag": { "type": "string" },
                "digest": { "type": "string" }
            }
        },
        "agentStage": {
            "type": "object",
            "additionalProperties": false,
            "required": ["harness", "model", "timeout", "maxTurns", "tokenBudget"],
            "properties": {
                "harness": { "type": "string" },
                "model": { "type": "string" },
                "timeout": { "$ref": "#/definitions/duration" },
                "maxTurns": { "type": "integer", "minimum": 1 },
                "tokenBudget": { "type": "integer", "minimum": 1 }
            }
        },
        "serviceAccount": {
            "type": "object",
            "additionalProperties": false,
            "required": ["create"],
            "properties": {
                "create": { "type": "boolean" },
                "name": { "type": "string" },
                "annotations": { "type": "object" }
            }
        },
        "service": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "port"],
            "properties": {
                "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
                "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
                "nodePort": { "type": ["integer", "null"], "minimum": 1, "maximum": 65535 },
                "annotations": { "type": "object" }
            }
        },
        "controllerNetworkPolicy": {
            "type": "object",
            "additionalProperties": false,
            "required": ["create"],
            "properties": {
                "create": { "type": "boolean" }
            }
        }
    },
    "properties": {
        "global": { "type": "object" },
        "config": {
            "type": "object",
            "additionalProperties": false,
            "required": ["logLevel", "reconcileInterval"],
            "properties": {
                "logLevel": { "$ref": "#/definitions/logLevel" },
                "reconcileInterval": { "$ref": "#/definitions/duration" },
                "extra": { "$ref": "#/definitions/extraEnv" }
            }
        },
        "image": {
            "type": "object",
            "additionalProperties": false,
            "required": ["repository", "pullPolicy"],
            "properties": {
                "repository": { "type": "string" },
                "tag": { "type": "string" },
                "pullPolicy": { "type": "string", "enum": ["IfNotPresent", "Always", "Never"] },
                "pullSecrets": { "type": "array", "items": { "type": "object" } }
            }
        },
        "nameOverride": { "type": "string" },
        "fullnameOverride": { "type": "string" },
        "crds": {
            "type": "object",
            "additionalProperties": false,
            "description": "patchy.bitwisemedia.uk CRD installation; keep guards the all-time FindingRollup data on uninstall",
            "properties": {
                "install": { "type": "boolean" },
                "keep": { "type": "boolean" }
            }
        },
        "commonLabels": { "type": "object" },
        "commonAnnotations": { "type": "object" },
        "github": {
            "type": "object",
            "additionalProperties": false,
            "required": ["appSecret", "webhookSecret"],
            "properties": {
                "appSecret": { "type": "string" },
                "webhookSecret": { "type": "string" },
                "baseURL": { "type": "string" }
            }
        },
        "anthropic": {
            "type": "object",
            "additionalProperties": false,
            "required": ["secret", "secretKey", "secretEnv"],
            "properties": {
                "secret": { "type": "string" },
                "secretKey": { "type": "string" },
                "secretEnv": {
                    "type": "string",
                    "enum": ["ANTHROPIC_API_KEY", "CLAUDE_CODE_OAUTH_TOKEN", "ANTHROPIC_AUTH_TOKEN"]
                }
            }
        },
        "webhook": {
            "type": "object",
            "description": "The single external entry point for the GitHub App's one webhook URL, fronting the webhook-controller",
            "additionalProperties": false,
            "required": ["ingress", "httpRoute"],
            "properties": {
                "host": { "type": "string" },
                "ingress": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["enabled"],
                    "properties": {
                        "enabled": { "type": "boolean" },
                        "className": { "type": "string" },
                        "annotations": { "type": "object" },
                        "tls": { "type": "array", "items": { "type": "object" } }
                    }
                },
                "httpRoute": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["enabled"],
                    "properties": {
                        "enabled": { "type": "boolean" },
                        "annotations": { "type": "object" },
                        "parentRefs": { "type": "array", "items": { "type": "object" } }
                    }
                }
            }
        },
        "webhookController": {
            "type": "object",
            "additionalProperties": false,
            "required": ["replicas", "config", "serviceAccount", "service", "networkPolicy"],
            "properties": {
                "image": { "$ref": "#/definitions/imageOverride" },
                "replicas": { "type": "integer", "minimum": 0 },
                "config": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["forwardTimeout"],
                    "properties": {
                        "forwardTimeout": { "$ref": "#/definitions/duration" },
                        "logLevel": { "$ref": "#/definitions/logLevel" },
                        "extra": { "$ref": "#/definitions/extraEnv" }
                    }
                },
                "resources": { "type": "object" },
                "podAnnotations": { "type": "object" },
                "podLabels": { "type": "object" },
                "nodeSelector": { "type": "object" },
                "tolerations": { "type": "array", "items": { "type": "object" } },
                "affinity": { "type": "object" },
                "serviceAccount": { "$ref": "#/definitions/serviceAccount" },
                "service": { "$ref": "#/definitions/service" },
                "networkPolicy": { "$ref": "#/definitions/controllerNetworkPolicy" }
            }
        },
        "sourceController": {
            "type": "object",
            "additionalProperties": false,
            "required": ["config", "serviceAccount", "service", "networkPolicy"],
            "properties": {
                "image": { "$ref": "#/definitions/imageOverride" },
                "config": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["accumulationWindow"],
                    "properties": {
                        "accumulationWindow": { "$ref": "#/definitions/duration" },
                        "logLevel": { "$ref": "#/definitions/logLevel" },
                        "reconcileInterval": { "$ref": "#/definitions/duration" },
                        "extra": { "$ref": "#/definitions/extraEnv" }
                    }
                },
                "resources": { "type": "object" },
                "podAnnotations": { "type": "object" },
                "podLabels": { "type": "object" },
                "nodeSelector": { "type": "object" },
                "tolerations": { "type": "array", "items": { "type": "object" } },
                "affinity": { "type": "object" },
                "serviceAccount": { "$ref": "#/definitions/serviceAccount" },
                "service": { "$ref": "#/definitions/service" },
                "networkPolicy": { "$ref": "#/definitions/controllerNetworkPolicy" }
            }
        },
        "contextController": {
            "type": "object",
            "additionalProperties": false,
            "required": ["config", "serviceAccount", "service", "networkPolicy"],
            "properties": {
                "image": { "$ref": "#/definitions/imageOverride" },
                "config": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["enhanceGrace"],
                    "properties": {
                        "enhanceGrace": { "$ref": "#/definitions/duration" },
                        "logLevel": { "$ref": "#/definitions/logLevel" },
                        "reconcileInterval": { "$ref": "#/definitions/duration" },
                        "extra": { "$ref": "#/definitions/extraEnv" }
                    }
                },
                "resources": { "type": "object" },
                "podAnnotations": { "type": "object" },
                "podLabels": { "type": "object" },
                "nodeSelector": { "type": "object" },
                "tolerations": { "type": "array", "items": { "type": "object" } },
                "affinity": { "type": "object" },
                "serviceAccount": { "$ref": "#/definitions/serviceAccount" },
                "service": { "$ref": "#/definitions/service" },
                "networkPolicy": { "$ref": "#/definitions/controllerNetworkPolicy" }
            }
        },
        "remediationController": {
            "type": "object",
            "additionalProperties": false,
            "required": ["config", "serviceAccount", "service", "networkPolicy"],
            "properties": {
                "image": { "$ref": "#/definitions/imageOverride" },
                "config": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                        "issueMinAge",
                        "maxAttempts",
                        "confidenceThreshold",
                        "jobDeadline",
                        "jobTTL",
                        "modelAllowlist",
                        "classify",
                        "remediate"
                    ],
                    "properties": {
                        "issueMinAge": { "$ref": "#/definitions/duration" },
                        "maxAttempts": { "type": "integer", "minimum": 1 },
                        "confidenceThreshold": { "type": ["string", "number"] },
                        "jobDeadline": { "$ref": "#/definitions/duration" },
                        "jobTTL": { "$ref": "#/definitions/duration" },
                        "modelAllowlist": { "type": "string" },
                        "classify": { "$ref": "#/definitions/agentStage" },
                        "remediate": { "$ref": "#/definitions/agentStage" },
                        "logLevel": { "$ref": "#/definitions/logLevel" },
                        "reconcileInterval": { "$ref": "#/definitions/duration" },
                        "extra": { "$ref": "#/definitions/extraEnv" }
                    }
                },
                "resources": { "type": "object" },
                "podAnnotations": { "type": "object" },
                "podLabels": { "type": "object" },
                "nodeSelector": { "type": "object" },
                "tolerations": { "type": "array", "items": { "type": "object" } },
                "affinity": { "type": "object" },
                "serviceAccount": { "$ref": "#/definitions/serviceAccount" },
                "service": { "$ref": "#/definitions/service" },
                "networkPolicy": { "$ref": "#/definitions/controllerNetworkPolicy" }
            }
        },
        "agent": {
            "type": "object",
            "additionalProperties": false,
            "required": ["namespace", "serviceAccount", "networkPolicy"],
            "properties": {
                "namespace": { "type": "string" },
                "createNamespace": { "type": "boolean" },
                "serviceAccount": { "type": "string" },
                "image": { "$ref": "#/definitions/imageOverride" },
                "networkPolicy": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["create", "cilium", "istio"],
                    "properties": {
                        "create": { "type": "boolean" },
                        "clusterCIDRs": { "type": "array", "items": { "type": "string" } },
                        "hosts": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "anthropic": { "type": "array", "items": { "type": "string" } },
                                "github": { "type": "array", "items": { "type": "string" } },
                                "dnsPatterns": { "type": "array", "items": { "type": "string" } }
                            }
                        },
                        "cilium": {
                            "type": "object",
                            "additionalProperties": false,
                            "required": ["enabled"],
                            "properties": {
                                "enabled": { "type": "boolean" }
                            }
                        },
                        "istio": {
                            "type": "object",
                            "additionalProperties": false,
                            "required": ["enabled"],
                            "properties": {
                                "enabled": { "type": "boolean" },
                                "istiodNamespace": { "type": "string" },
                                "injectionLabel": { "type": "string" },
                                "injectionValue": { "type": "string" }
                            }
                        }
                    }
                }
            }
        }
    }
}
