# Controller image. One Dockerfile, four images — built by GoReleaser
# (`dockers_v2` in .goreleaser.yaml), which compiles the binaries first and
# hands this file a build context containing ONLY those binaries, laid out as
# $TARGETPLATFORM/<binary> (e.g. linux/amd64/source-controller). There is no
# Go toolchain or source here: version metadata is already stamped into
# internal/version by GoReleaser's ldflags, and the same buildx invocation
# produces the linux/amd64 + linux/arm64 manifest.
#
# All four controllers share the same distroless-static runtime: pure Go,
# CGO off, no external process is ever executed. The remediation-controller
# pushes agent changesets through the GitHub API (internal/ghpush), so no git
# binary is needed anywhere.
#
# TARGET (the binary to copy) is supplied by the per-image `build_args` in
# .goreleaser.yaml. Build locally (no publish) with `make snapshot` — needs
# docker + buildx.
#
# Runs as uid 65532 ("nonroot"), matching internal/jobs' runAsUser, and works
# under readOnlyRootFilesystem.

FROM gcr.io/distroless/static-debian13:nonroot@sha256:f7f8f729987ad0fdf6b05eeeae94b26e6a0f613bdf46feea7fc40f7bd72953e6

ARG TARGETPLATFORM
ARG TARGET

# The binary lands at a fixed path so ENTRYPOINT need not interpolate TARGET
# (exec-form ENTRYPOINT cannot expand build args). The Deployment supplies the
# subcommand: args: ["serve"].
COPY ${TARGETPLATFORM}/${TARGET} /usr/local/bin/controller

USER 65532:65532
EXPOSE 8080
ENTRYPOINT ["/usr/local/bin/controller"]
