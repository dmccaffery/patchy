# Agent image. Used for BOTH containers of the ephemeral Job that
# internal/jobs creates:
#
#   initContainer "prepare" — runs /bin/sh with the clone script (needs sh,
#     git and the GitHub token; the token never reaches the agent container).
#   container "agent"       — runs `agent-runner` (must be on PATH under that
#     exact name: internal/jobs sets Command: []string{"agent-runner"}), which
#     execs `claude -p ...` (internal/harness) and `git` (changeset diffing).
#
# So the image must carry: the agent-runner binary, git, /bin/sh, and the
# claude CLI (which needs node) — that rules out distroless; node:24-trixie-slim
# is the smallest sane base.
#
# Built by GoReleaser (`dockers_v2` in .goreleaser.yaml): the agent-runner
# binary is compiled by GoReleaser and arrives in the build context at
# $TARGETPLATFORM/agent-runner — no Go toolchain or source here.
#
# readOnlyRootFilesystem: internal/jobs runs both containers with a read-only
# root filesystem, uid 65532, all capabilities dropped. The only writable
# paths are /workspace (emptyDir, and HOME) and /tmp (emptyDir). Nothing in
# this image may write outside those at runtime: npm's global install happens
# at build time, and claude keeps its state under $HOME=/workspace.
FROM node:24-trixie-slim@sha256:ae91dcc111a68c9d2d81ff2a17bda61be126426176fde6fe7d08ab13b7f50573

# Pinned claude CLI version. Dependabot/renovate should bump this ARG (npm
# package @anthropic-ai/claude-code); pin it so an agent image is reproducible
# and a harness regression is attributable to a known version.
# renovate: datasource=npm depName=@anthropic-ai/claude-code
ARG CLAUDE_VERSION=2.0.14

# hadolint ignore=DL3008
RUN apt-get update \
    && apt-get install --no-install-recommends -y ca-certificates git \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g "@anthropic-ai/claude-code@${CLAUDE_VERSION}" \
    && npm cache clean --force

ARG TARGETPLATFORM
COPY ${TARGETPLATFORM}/agent-runner /usr/local/bin/agent-runner

# uid 65532 matches internal/jobs' runAsUser (and the distroless "nonroot"
# convention). the node image's own "node" user is uid 1000, so create ours.
RUN groupadd --gid 65532 nonroot \
    && useradd --uid 65532 --gid 65532 --no-create-home --shell /sbin/nologin nonroot

# HOME is overridden to /workspace by the Job (the only writable dir); this is
# only the sane default for a bare `docker run`.
ENV HOME=/workspace
WORKDIR /workspace

USER 65532:65532
ENTRYPOINT ["agent-runner"]
