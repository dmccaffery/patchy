# Agent image. Used for BOTH containers of the ephemeral Job that
# internal/jobs creates:
#
#   initContainer "prepare" — runs /bin/sh with the clone script (needs sh,
#     git and the GitHub token; the token never reaches the agent container).
#   container "agent"       — runs `agent-runner` (must be on PATH under that
#     exact name: internal/jobs sets Command: []string{"agent-runner"}), which
#     execs `claude -p ...` (internal/harness) and `git` (changeset diffing).
#
# So the image must carry: the agent-runner binary, git, /bin/sh, and the
# claude CLI. claude ships as a self-contained native binary (ripgrep
# bundled; glibc its only runtime need), so the runtime base is plain
# debian:trixie-slim — no node, no npm, no node_modules. The fetch stage
# below downloads the pinned version and refuses anything whose sha256 does
# not match the release manifest; only the verified binary reaches the
# runtime stage.
#
# Built by GoReleaser (`dockers_v2` in .goreleaser.yaml): the agent-runner
# binary is compiled by GoReleaser and arrives in the build context at
# $TARGETPLATFORM/agent-runner — no Go toolchain or source here.
#
# readOnlyRootFilesystem: internal/jobs runs both containers with a read-only
# root filesystem, uid 65532, all capabilities dropped. The only writable
# paths are /workspace (emptyDir, and HOME) and /tmp (emptyDir). Nothing in
# this image may write outside those at runtime: claude keeps its state under
# $HOME=/workspace, and DISABLE_AUTOUPDATER pins it to the baked version.
FROM debian:trixie-slim@sha256:020c0d20b9880058cbe785a9db107156c3c75c2ac944a6aa7ab59f2add76a7bd AS fetch

# hadolint ignore=DL3008
RUN apt-get update \
    && apt-get install --no-install-recommends -y ca-certificates curl jq \
    && rm -rf /var/lib/apt/lists/*

# Pinned claude CLI version. Dependabot/renovate should bump this ARG: the
# native binaries are released in lockstep with the npm package
# (@anthropic-ai/claude-code) under the same version numbers, so the npm
# datasource stays the source of truth; pin it so an agent image is
# reproducible and a harness regression is attributable to a known version.
# renovate: datasource=npm depName=@anthropic-ai/claude-code
ARG CLAUDE_VERSION=2.0.14

# Fetch the native binary for the target platform from the official release
# bucket (what https://claude.ai/install.sh resolves to) and verify it
# against the version's manifest before it leaves this stage. `jq -e` fails
# the build on a missing platform; the grep guards against a manifest whose
# checksum field is not a sha256.
ARG TARGETARCH
# hadolint ignore=DL4006
RUN case "${TARGETARCH}" in \
        amd64) platform=linux-x64 ;; \
        arm64) platform=linux-arm64 ;; \
        *) echo "unsupported TARGETARCH: ${TARGETARCH}" >&2; exit 1 ;; \
    esac \
    && base="https://downloads.claude.ai/claude-code-releases" \
    && curl -fsSL -o /tmp/manifest.json "${base}/${CLAUDE_VERSION}/manifest.json" \
    && checksum="$(jq -er ".platforms[\"${platform}\"].checksum" /tmp/manifest.json)" \
    && echo "${checksum}" | grep -qE '^[0-9a-f]{64}$' \
    && curl -fsSL -o /claude "${base}/${CLAUDE_VERSION}/${platform}/claude" \
    && echo "${checksum}  /claude" | sha256sum -c - \
    && chmod 0755 /claude

FROM debian:trixie-slim@sha256:020c0d20b9880058cbe785a9db107156c3c75c2ac944a6aa7ab59f2add76a7bd

# curl serves the init container's credential-less artifact fetch (the
# SHA-pinned repo tarball from source-controller); git serves the agent's
# commit/diff flow.
# hadolint ignore=DL3008
RUN apt-get update \
    && apt-get install --no-install-recommends -y ca-certificates curl git \
    && rm -rf /var/lib/apt/lists/*

COPY --from=fetch /claude /usr/local/bin/claude

ARG TARGETPLATFORM
COPY ${TARGETPLATFORM}/agent-runner /usr/local/bin/agent-runner

# uid 65532 matches internal/jobs' runAsUser (and the distroless "nonroot"
# convention). create it: a bare debian image has no non-root user.
RUN groupadd --gid 65532 nonroot \
    && useradd --uid 65532 --gid 65532 --no-create-home --shell /sbin/nologin nonroot

# The native claude binary self-updates by default; an image pins a version
# and runs on a read-only rootfs, so updating must never be attempted.
ENV DISABLE_AUTOUPDATER=1

# HOME is overridden to /workspace by the Job (the only writable dir); this is
# only the sane default for a bare `docker run`.
ENV HOME=/workspace
WORKDIR /workspace

USER 65532:65532
ENTRYPOINT ["agent-runner"]
